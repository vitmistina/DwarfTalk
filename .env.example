# LLM provider
#
# Default should remain Fake so local development and tests do not burn API credits.
FortressSouls__Llm__ProviderType=Fake

# First real provider target for v0.1:
# FortressSouls__Llm__ProviderType=OpenAiCompatible
FortressSouls__Llm__Endpoint=https://openrouter.ai/api/v1
FortressSouls__Llm__Model=deepseek/deepseek-v3.2
FortressSouls__Llm__ApiKey=

# Plain dwarf chat defaults
FortressSouls__Llm__MaxOutputTokens=500
FortressSouls__Llm__Temperature=0.85
FortressSouls__Llm__TimeoutSeconds=45
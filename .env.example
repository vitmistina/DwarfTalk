# Secrets and secret-adjacent overrides for local development.
#
# Non-secret runtime choices now belong in fortress-souls.config.jsonc.
# Keep this file for credentials only.

# Real provider API key.
# Leave blank when running with the Fake provider.
FortressSouls__Llm__ApiKey=

# Optional local OTLP auth headers if your collector requires them.
# OTEL_EXPORTER_OTLP_HEADERS=